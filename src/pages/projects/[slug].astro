---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Frame from "../../components/Frame.astro";
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'projects'> };

console.log(Astro.props);

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, tech_stack, description, links, created_at, progress, script } = entry.data;

const width = "72vw";
const height = "72vh";
const frame_tr = "frame_tr";
---

<BaseLayout pageTitle={title}>
    <Frame width={width} height={height} frame_tr={frame_tr}>
        <section>
            <div class="left">
                <h1>{title}<span class="dot">.</span></h1>
                <div class="data">
                    <div class="tech_stack">
                        <strong>Tech_Stack:</strong>
                        <ul>
                            {tech_stack.map((tech) => (
                                <li>{tech.name}<span class="dot_tech" style={`background: ${tech.color};`}></span></li>
                            ))}
                        </ul>
                    </div>
                    <div class="description">
                        <strong>Description:</strong>
                        <p>{description}</p>
                    </div>
                    {links.length > 0 && (
                        <div class="links">
                            <strong>Links:</strong>
                            <div class="all">
                                {links.map((link) => (
                                    <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
                                ))}
                            </div>
                        </div>
                    )}
                    <div class="created_at">
                        <strong>Created_at:</strong>
                        <p>{created_at}</p>
                    </div>
                    <div class="progress">
                        <strong>Progression:</strong>
                        <div class="progress_bar">
                            <div id="progress_fill" style={`width: ${progress}%;`}></div>
                        </div>
                        <p>{progress}%</p>
                    </div>
                </div>
            </div>
            <div class="right">
                <Content />
            </div>
        </section>
    </Frame>
    <script src="../../scripts/project_scripts.js" />
</BaseLayout>

<style lang="scss">
    section
    {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 72vw;
        height: 72vh;
        padding: 32px;
    }

    h1
    {
        display: flex;
        margin-bottom: 3.2vh;
    }

    .dot
    {
        color: var(--clr-span);
        margin: 0;
    }

    .left,
    .right
    {
        width: 50%;
    }

    .left .data
    {
        width: 100%;
        height: 54vh;
        padding-right: 12px;
        overflow-y: auto;
    }

    .left .data::-webkit-scrollbar
    {
        border-radius: 10px;
        box-shadow: inset 1px 1px 4px rgb(186,196,214);
    }

    .left .data::-webkit-scrollbar-thumb
    {
        background: #d6dee9;
        border-radius: 10px;
        opacity: .8;
    }

    .left .data::-webkit-scrollbar-corner
    {
        background: #ecf0f3;
    }

    strong
    {
        font-size: calc(.6rem + .8vw);
        font-weight: 400;
        margin-right: calc(4px + .8vw);
    }

    .dot_tech
    {
        display: block;
        width: calc(4px + .8vw);
        height: calc(4px + .8vw);
        margin-left: calc(4px + .2vw);
        margin-right: calc(8px + .4vw);
        border-radius: 16px;
        flex-shrink: 0;
    }

    .left .data div
    {
        display: flex;
        align-items: flex-start;
        font-size: calc(.36rem + .8vw);
        margin-top: 8px;
    }

    .left .tech_stack ul,
    .left .description p,
    .left .links .all,
    .left .created_at p
    {
        margin-top: 4px;
    }

    .left .tech_stack ul, li
    {
        display: flex;
        flex-wrap: wrap;
    }

    ul li
    {
        display: flex;
        align-items: center;
    }

    .left .links .all
    {
        display: flex;
        flex-direction: column;
    }

    .left .links .all a
    {
        color: var(--clr-font);
        text-decoration: underline;
    }

    .left .data .progress
    {
        display: flex;
        align-items: center;
        font-size: calc(.72rem + .36vw);
    }

    .progress_bar
    {
        width: 24vw;
        height: 1.6vh;
        background: rgba(186,196,214,.3);
        border-radius: 12px;
        overflow: hidden;
    }

    #progress_fill
    {
        max-width: 100%;
        height: 100%;
        margin: 0px;
        background: linear-gradient(0.25turn, #adcc00, #6eb41e);
        border-radius: 12px;
    }

    .left .progress p
    {
        margin: 5px 0 0 4px;
    }

    .right
    {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        width: 46%;
        height: 96%;
        margin-right: 1%;
        padding: 24px;
        border-radius: 24px;
        box-shadow: 4px 4px 12px var(--clr-shadow);
    }

    @media(max-width:940px)
    {
        section
        {
            flex-direction: column;
            overflow-y: scroll;
        }

        section::-webkit-scrollbar
        {
            border-radius: 10px;
            box-shadow: inset 1px 1px 4px rgb(186,196,214);
        }

        section::-webkit-scrollbar-thumb
        {
            background: #d6dee9;
            border-radius: 10px;
            opacity: .8;
        }

        section::-webkit-scrollbar-corner
        {
            background: #ecf0f3;
        }

        .left
        {
            width: 100%;
        }

        .left .data
        {
            height: auto;
            margin-bottom: 4vh;
            padding-right: 0;
        }

        .left .data .tech_stack ul, .data .all, .created_at p
        {
            margin-top: 2px;
        }

        .right
        {
            width: 100%;
            margin-right: 0;
        }
    }

    @media(max-width: 640px)
    {
        .left .data .tech_stack ul,
        .left .description p,
        .left .links .all,
        .left .created_at p,
        .progress_bar,
        .left .progress p
        {
            margin-top: 0;
        }
    }
</style>
